# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/famtree"

# ─── Auth ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="replace-with-64-char-random-secret"
JWT_EXPIRES_IN="7d"

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_NAME="FamTree"

# ─── Email (Resend) ──────────────────────────────────────────
# Get from: https://resend.com
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="FamTree <noreply@yourdomain.com>"

# ─── File Storage ────────────────────────────────────────────
# Option A: Local (dev only) - photos saved to /public/uploads
UPLOAD_DIR="./public/uploads"

# Option B: Cloudflare R2 (production)
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=""          # Cloudflare account ID (top-right of any CF page)
R2_ACCESS_KEY_ID=""       # R2 token → Access Key ID
R2_SECRET_ACCESS_KEY=""   # R2 token → Secret Access Key
R2_BUCKET_NAME=""         # e.g. famtree-uploads
R2_PUBLIC_URL=""          # e.g. https://assets.yourdomain.com  (R2 public bucket URL)
