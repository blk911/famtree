// famtree/prisma/schema.prisma
// Local: npm run db:push && prisma generate
// Vercel: build runs prisma db push (see vercel.json) so production Postgres matches this schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  dateOfBirth   DateTime?
  photoUrl      String?   // stored in /public/uploads or S3
  role          String    @default("member") // "founder" | "admin" | "member"
  status        String    @default("active") // "active" | "suspended" | "archived" | "blocked"
  relationship  String?   // relationship to founder, set at invite time: "parent"|"child"|"sibling"|"spouse"|"so"|"frnd"|"other"
  emailVerified Boolean   @default(false)
  lastLoginAt   DateTime?                  // set on each login; prev session = "last seen" baseline
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile (1-to-1)
  profile       Profile?

  // Tree placement — who invited this user (durable, survives invite record deletion)
  invitedById   String?
  invitedBy     User?     @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers  User[]    @relation("InvitedBy")

  // Invites this user has SENT
  sentInvites   Invite[]  @relation("SentInvites")

  // Sessions
  sessions      Session[]

  // Social activity
  likes           Like[]
  comments        Comment[]
  postVisibility  PostVisibility[]
  dashboardSpaceMemberships DashboardSpaceMember[]

  // Trust graph
  createdTrustUnitRequests TrustUnitRequest[]       @relation("TrustUnitRequestCreator")
  trustUnitRequestMembers  TrustUnitRequestMember[]
  trustUnitApprovals       TrustUnitApproval[]
  trustUnitMembers         TrustUnitMember[]
  sentConnectionRequests   ConnectionRequest[]      @relation("ConnectionRequester")
  receivedConnectionRequests ConnectionRequest[]    @relation("ConnectionTarget")

  treePrefsAsViewer TreeViewPreference[] @relation("TreePrefsViewer")
  treePrefsAsTarget TreeViewPreference[] @relation("TreePrefsTarget")

  // Identity change workflow — first approved change consumes self-service; admin unlock restores one slot.
  selfServiceIdentityChangesRemaining Int @default(1)

  identityChangeRequests          IdentityChangeRequest[]       @relation("ICRRequester")
  identityChangesAdministered     IdentityChangeRequest[]       @relation("ICRAdmin")
  identityChangeAcknowledgments   IdentityChangeAcknowledgment[] @relation("ICAckInvitee")

  /// Optional tenant slug for studio / white-label owners (e.g. deb-dazzle)
  tenantId String? @map("tenant_id")

  /// Auto sign-out after true inactivity while logged in (minutes). Allowed: 3 / 5 / 10 only.
  idleTimeoutMinutes Int @default(5)

  studiosOwned Studio[]

  // AIH Safe — back-relations (added by Agent 3)
  aihFamilyUnitsCreated      AihFamilyUnit[]            @relation("AihFamilyUnitCreatedBy")
  aihFamilyUnitMemberships   AihFamilyUnitMember[]      @relation("AihFamilyUnitMember")
  aihGuardianRelationships   AihGuardianRelationship[]  @relation("AihGuardianOf")
  aihGuardedByRelationships  AihGuardianRelationship[]  @relation("AihChildOf")
  aihApprovalRequestsMade    AihApprovalRequest[]       @relation("AihApprovalRequestor")
  aihApprovalRequestsPending AihApprovalRequest[]       @relation("AihApprovalApprover")
  // Activity layer (Agent 19)
  aihActivityPosts           AihActivityPost[]          @relation("AihActivityPostAuthor")
  aihActivityComments        AihActivityComment[]       @relation("AihActivityCommentAuthor")
  // Policy layer (Agent 37)
  aihPolicyProfile           AihPolicyProfile?

  // Msg Vault — governed communication (Agent 49)
  aihMsgConversationsCreated AihMsgConversation[]     @relation("AihMsgConversationCreatedBy")
  aihMsgParticipants         AihMsgParticipant[]
  aihMsgMessagesAuthored     AihMsgMessage[]          @relation("AihMsgMessageAuthor")
  aihMsgNotices              AihMsgNotice[]
  aihMsgGovernanceEvents     AihMsgGovernanceEvent[]  @relation("AihMsgGovernanceEventActor")

  @@map("users")
}

// ─────────────────────────────────────────────
// STUDIOS & SERVICE TIERS (e.g. Deb Dazzle)
// ─────────────────────────────────────────────
model Studio {
  id        String   @id
  name      String
  slug      String   @unique
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tagline   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tiers StudioServiceTier[]
  voiceProfile StudioVoiceProfile?

  @@map("studios")
}

model StudioVoiceProfile {
  id                 String   @id @default(cuid())
  studioId           String   @unique
  studio             Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  tone               String   @default("warm_curator")
  greetingStyle      String   @db.Text @default("Hey — thanks for being here. What are you hoping to find today?")
  businessType       String   @default("studio")
  escalationPhrase   String   @db.Text @default("Oh! My next client just walked in — drop your number and I'll text you as soon as I'm free.")
  communicationStyle String   @default("concierge")
  offersSummary      String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("studio_voice_profiles")
}

/// AIH Studios concierge — Postgres persistence (Firestore-style collections mapped here).
model ConciergeChatSession {
  id               String   @id @default(cuid())
  visitorToken     String
  contextKey       String
  mode             String
  funnelStage      String   @default("greeting")
  status           String   @default("active")
  confusionSignals Int      @default(0)
  takeoverUserId   String?
  summaryLine      String?  @db.Text
  lastAiConfidence Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  messages   ConciergeChatMessage[]
  leads      ConciergeLeadCapture[]
  summaries  ConciergeConversationSummary[]

  @@unique([visitorToken, contextKey])
  @@index([contextKey, status])
  @@map("concierge_chat_sessions")
}

model ConciergeChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  session   ConciergeChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("concierge_chat_messages")
}

model ConciergeLeadCapture {
  id                  String   @id @default(cuid())
  sessionId           String
  session             ConciergeChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  phone               String?
  email               String?
  igHandle            String?
  conversationSummary String?  @db.Text
  status              String   @default("new")
  createdAt           DateTime @default(now())

  @@index([sessionId])
  @@index([status])
  @@map("concierge_lead_captures")
}

model ConciergeConversationSummary {
  id        String   @id @default(cuid())
  sessionId String
  session   ConciergeChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  summary   String   @db.Text
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("concierge_conversation_summaries")
}

model ConciergeClientMemory {
  id           String   @id @default(cuid())
  visitorToken String
  contextKey   String
  notes        String   @db.Text
  updatedAt    DateTime @updatedAt

  @@unique([visitorToken, contextKey])
  @@map("concierge_client_memories")
}

model StudioServiceTier {
  id        String   @id @default(cuid())
  studioId  String
  studio    Studio   @relation(fields: [studioId], references: [id], onDelete: Cascade)
  name      String
  price     Decimal? @db.Decimal(10, 2)
  sortOrder Int      @default(0)

  @@unique([studioId, name])
  @@map("studio_service_tiers")
}

// ─────────────────────────────────────────────
// PROFILES  (social media page per member)
// ─────────────────────────────────────────────
model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  bio         String?
  familyRole  String?  // "parent" | "grandparent" | "sibling" | "cousin" | "child" | "other"
  location    String?
  coverUrl    String?
  phone       String?

  // Privacy
  isPublicInTree Boolean @default(true)  // visible to all tree members
  showDob        Boolean @default(false)

  // Dashboard onboarding prompt state
  dashboardProfilePromptDismissedAt DateTime?
  dashboardProfilePromptSeenCount   Int       @default(0)

  // Timeline posts
  posts       Post[]

  // Photos
  photos      Photo[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("profiles")
}

// ─────────────────────────────────────────────
// DASHBOARD SPACES (BUSINESS / CLUB / CHURCH membership for scoped posts)
// ─────────────────────────────────────────────
enum DashboardSpaceKind {
  BUSINESS
  CLUB
  CHURCH
}

model DashboardSpace {
  id        String             @id @default(uuid())
  kind      DashboardSpaceKind
  name      String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  members   DashboardSpaceMember[]
  posts     Post[]

  @@map("dashboard_spaces")
}

model DashboardSpaceMember {
  id        String         @id @default(cuid())
  spaceId   String
  space     DashboardSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@unique([spaceId, userId])
  @@map("dashboard_space_members")
}

// ─────────────────────────────────────────────
// POSTS  (timeline entries on a profile)
// ─────────────────────────────────────────────
enum DashboardPostScope {
  FAMILY
  BUSINESS
  CLUB
  CHURCH
  PRIVATE
}

model Post {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  title     String?
  body      String
  imageUrl  String?
  /// Permission scope for dashboard / family vault feeds (server-enforced).
  scope     DashboardPostScope @default(FAMILY)
  /// When scope is BUSINESS | CLUB | CHURCH, must reference a space the author belongs to.
  spaceId   String?
  space     DashboardSpace? @relation(fields: [spaceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  likes      Like[]
  comments   Comment[]
  visibility PostVisibility[]

  @@map("posts")
}

// Per-post visibility — empty = visible to all members
model PostVisibility {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@map("post_visibility")
}

// Likes on posts
model Like {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@map("likes")
}

// Comments on posts
model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())

  @@map("comments")
}

// ─────────────────────────────────────────────
// PHOTOS  (photo gallery on a profile)
// ─────────────────────────────────────────────
model Photo {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  url       String
  caption   String?
  takenAt   DateTime?
  createdAt DateTime @default(now())

  @@map("photos")
}

// ─────────────────────────────────────────────
// INVITES  (the identity-gate invite system)
// ─────────────────────────────────────────────
model Invite {
  id             String       @id @default(uuid())
  token          String       @unique @default(uuid())

  // Who sent it
  senderId       String
  sender         User         @relation("SentInvites", fields: [senderId], references: [id])

  // Who it was sent to
  recipientEmail String

  // Status
  status         InviteStatus @default(PENDING)
  attempts       Int          @default(0)
  maxAttempts    Int          @default(3)

  // Relationship sender has to recipient (e.g. "parent", "child", "spouse", "so", "frnd", "sibling", "other")
  relationship   String?

  // Agent 73 — invite intent routing (see types/aihsafe/invite-intent.ts)
  inviteIntent          String?   // adult_friend | family_adult | adult_child | child | teen | trusted_adult | business_member | business_admin
  relationshipKind      String?   // normalized edge for graph/governance
  inviteeAgeBracket     String?   // child | teen | adult | unknown
  stewardDeclaration    Boolean   @default(false)
  sponsorUserId         String?   // usually senderId; explicit sponsor for delegated sends
  stewardUserId         String?   // declared family steward for child/teen intents
  targetTrustUnitId     String?   // business / workspace scope
  targetFamilyUnitId    String?   // family unit scope

  // Timestamps
  expiresAt      DateTime     // 7 days from creation
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  trustUnitPendingSlots TrustUnitRequestPendingInvite[]

  @@map("invites")
}

enum InviteStatus {
  PENDING    // sent, not yet attempted
  ACCEPTED   // identity verified, awaiting registration
  REGISTERED // account successfully created — terminal state
  EXPIRED    // time or attempts exhausted
  CANCELLED  // sender revoked
}

// Per-viewer display only: how `viewerId` sees `targetId` on their tree.
// Never changes User.status and is not visible to other viewers. Each member has their own rows.
model TreeViewPreference {
  id        String   @id @default(cuid())
  viewerId  String
  targetId  String
  muted     Boolean  @default(false)
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  viewer User @relation("TreePrefsViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  target User @relation("TreePrefsTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([viewerId, targetId])
  @@map("tree_view_preferences")
}

// ─────────────────────────────────────────────
// TRUST UNITS  (3-person trusted relationship groups)
// ─────────────────────────────────────────────
model TrustUnit {
  id        String            @id @default(cuid())
  status    TrustUnitStatus   @default(ACTIVE)
  createdAt DateTime          @default(now())
  members   TrustUnitMember[]

  // AIH Safe — back-relations (added by Agent 3 / Agent 19)
  aihMeta          AihTrustUnitMeta?
  aihActivityPosts AihActivityPost[]
  aihMsgConversations AihMsgConversation[]

  @@map("trust_units")
}

model TrustUnitMember {
  id          String    @id @default(cuid())
  trustUnitId String
  trustUnit   TrustUnit @relation(fields: [trustUnitId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([trustUnitId, userId])
  @@map("trust_unit_members")
}

model TrustUnitRequest {
  id          String                   @id @default(cuid())
  createdById String
  createdBy   User                     @relation("TrustUnitRequestCreator", fields: [createdById], references: [id], onDelete: Cascade)
  status      TrustUnitRequestStatus   @default(PENDING)
  createdAt   DateTime                 @default(now())
  members     TrustUnitRequestMember[]
  approvals   TrustUnitApproval[]
  pendingInviteSlots TrustUnitRequestPendingInvite[]

  @@map("trust_unit_requests")
}

/// Registered invitee not yet on the network — resolves to a TrustUnitRequestMember when they register.
model TrustUnitRequestPendingInvite {
  id        String           @id @default(cuid())
  requestId String
  request   TrustUnitRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  inviteId  String           @unique
  invite    Invite           @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@unique([requestId, inviteId])
  @@map("trust_unit_request_pending_invites")
}

model TrustUnitRequestMember {
  id        String           @id @default(cuid())
  requestId String
  request   TrustUnitRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([requestId, userId])
  @@map("trust_unit_request_members")
}

model TrustUnitApproval {
  id        String              @id @default(cuid())
  requestId String
  request   TrustUnitRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    TrustApprovalStatus @default(PENDING)
  updatedAt DateTime            @updatedAt

  @@unique([requestId, userId])
  @@map("trust_unit_approvals")
}

model ConnectionRequest {
  id          String                  @id @default(cuid())
  requesterId String
  requester   User                    @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  targetId    String
  target      User                    @relation("ConnectionTarget", fields: [targetId], references: [id], onDelete: Cascade)
  status      ConnectionRequestStatus @default(PENDING)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@unique([requesterId, targetId])
  @@map("connection_requests")
}

enum TrustUnitStatus {
  ACTIVE
  /// Flagged by system scrub — contained an admin/system account; audit retained.
  NEEDS_REFORM_SYSTEM_EXCLUDED
}

enum TrustUnitRequestStatus {
  PENDING
  ACTIVE
  DECLINED
  /// Cancelled by system scrub — proposal contained an admin/system participant.
  CANCELLED_SYSTEM_EXCLUDED
}

enum TrustApprovalStatus {
  PENDING
  APPROVED
  DECLINED
}

enum ConnectionRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  /// Revoked by system scrub — bond touched an admin/system account.
  REVOKED_SYSTEM_EXCLUDED
}

// ─────────────────────────────────────────────
// WAITLIST  (users who requested an invite — no account yet)
// ─────────────────────────────────────────────
// Users who requested an invite — no account yet
model Waitlist {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  createdAt DateTime @default(now())

  @@map("waitlist")
}

// ─────────────────────────────────────────────
// IDENTITY CHANGE REQUESTS  (name / email / cell — invitee ack + admin)
// ─────────────────────────────────────────────
model IdentityChangeRequest {
  id          String   @id @default(cuid())
  requesterId String
  requester   User     @relation("ICRRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  status      String   // PENDING_ACKS | PENDING_ADMIN | APPROVED | REJECTED | WITHDRAWN | EXPIRED

  prevFirstName String
  prevLastName  String
  prevEmail     String
  prevPhone     String?

  proposedFirstName String?
  proposedLastName  String?
  proposedEmail     String?
  proposedPhone     String?

  changeName  Boolean @default(false)
  changeEmail Boolean @default(false)
  changePhone Boolean @default(false)

  requesterNote String @db.Text

  hasConflict Boolean @default(false)

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resolvedAt DateTime?
  adminId    String?
  admin      User?    @relation("ICRAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  adminNote  String?  @db.Text

  acknowledgments IdentityChangeAcknowledgment[]

  @@index([requesterId])
  @@index([status])
  @@map("identity_change_requests")
}

model IdentityChangeAcknowledgment {
  id        String   @id @default(cuid())
  requestId String
  request   IdentityChangeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  inviteeId String
  invitee   User     @relation("ICAckInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  response    String?   // YES | NO
  respondedAt DateTime?

  @@unique([requestId, inviteeId])
  @@map("identity_change_acknowledgments")
}

// ─────────────────────────────────────────────
// PASSWORD RESET TOKENS
// ─────────────────────────────────────────────
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(uuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ─────────────────────────────────────────────
// ACTIVITY LOG  (admin audit trail)
// ─────────────────────────────────────────────
model ActivityLog {
  id          String   @id @default(cuid())
  actorId     String                          // who performed the action
  actorName   String                          // snapshot — survives actor deletion
  action      String                          // e.g. "invite.cancel" | "member.suspend"
  detail      String                          // human-readable one-liner
  createdAt   DateTime @default(now())

  @@map("activity_logs")
}

// ─────────────────────────────────────────────
// SITE ANNOUNCEMENTS  (admin broadcast messages)
// ─────────────────────────────────────────────
model SiteAnnouncement {
  id          String             @id @default(cuid())
  title       String
  body        String
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdById String
  views       AnnouncementView[]

  @@map("site_announcements")
}

model AnnouncementView {
  id             String           @id @default(cuid())
  userId         String
  announcementId String
  viewCount      Int              @default(1)
  dismissedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  announcement SiteAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
  @@map("announcement_views")
}

// ─────────────────────────────────────────────
// MEMBER VIDEO MESSAGES  (admin intro / watch-once slots)
// ─────────────────────────────────────────────
model MemberVideoMessage {
  id          String   @id @default(cuid())
  slug        String   // e.g. "dashboard-intro"
  title       String
  caption     String   @default("Watch Once")
  videoUrl    String?  // MP4 or direct stream URL (HeyGen export, Blob, etc.)
  notes       String?  // admin-only context for offline updates
  isEnabled   Boolean  @default(false)
  watchOnce   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  completions MemberVideoCompletion[]

  @@index([slug, isEnabled])
  @@map("member_video_messages")
}

model MemberVideoCompletion {
  id          String   @id @default(cuid())
  userId      String
  messageId   String
  message     MemberVideoMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, messageId])
  @@map("member_video_completions")
}

// ─────────────────────────────────────────────
// SESSIONS  (simple JWT refresh tracking)
// ─────────────────────────────────────────────
model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

// ═══════════════════════════════════════════════════════════════════════════════
// AIH SAFE — ADDITIVE MODELS
// All models here are additive. No existing model is modified.
// Enums prefixed with Aih to avoid collision with existing schema enums.
// Tables prefixed with aih_ per @@map convention.
// Phase: 3 — persistence foundation for graph/audit/context services.
// ═══════════════════════════════════════════════════════════════════════════════

// ─── AIH Safe Enums ─────────────────────────────────────────────────────────

enum AihGuardianKind {
  parent
  grandparent
  legal_guardian
  trusted_adult

  @@map("aih_guardian_kind")
}

enum AihGuardianPermLevel {
  view_only
  approver
  full_control

  @@map("aih_guardian_perm_level")
}

enum AihFamilyUnitStatus {
  active
  dissolved

  @@map("aih_family_unit_status")
}

enum AihFamilyMemberRole {
  guardian
  child
  adult

  @@map("aih_family_member_role")
}

enum AihTrustUnitKind {
  family
  peer
  extended
  guardian

  @@map("aih_trust_unit_kind")
}

/// Msg Vault — operator-facing space category (drives labels + scoped activity UX).
enum AihVaultSpaceType {
  FAMILY
  BUSINESS
  CHURCH
  CLUB
  PRIVATE
  CUSTOM

  @@map("aih_vault_space_type")
}

enum AihApprovalState {
  pending
  approved
  denied
  revoked
  expired

  @@map("aih_approval_state")
}

// ─── AIH Safe Models ────────────────────────────────────────────────────────

/// 1:1 sidecar for existing TrustUnit — adds AIH Safe metadata without modifying the core model.
model AihTrustUnitMeta {
  trustUnitId            String             @id
  trustUnit              TrustUnit          @relation(fields: [trustUnitId], references: [id], onDelete: Restrict)
  kind                   AihTrustUnitKind
  /// Vault category — titles like "Business Space" and activity chips like "Shared in Business".
  vaultSpaceType         AihVaultSpaceType?
  description            String?            @db.Text
  name                   String?
  defaultVisibilityScope String             @default("trust_unit")
  maxMemberCount         Int                @default(3)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@map("aih_trust_unit_meta")
}

/// Named family grouping — one or more guardians + zero or more children.
/// Not the same as TrustUnit (which is for peer trust groups).
model AihFamilyUnit {
  id              String              @id @default(cuid())
  name            String
  status          AihFamilyUnitStatus @default(active)
  createdByUserId String
  createdBy       User                @relation("AihFamilyUnitCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  dissolvedAt     DateTime?

  members AihFamilyUnitMember[]

  @@index([createdByUserId])
  @@index([status])
  @@map("aih_family_units")
}

/// Join table — User to AihFamilyUnit with a role.
model AihFamilyUnitMember {
  id           String              @id @default(cuid())
  familyUnitId String
  familyUnit   AihFamilyUnit       @relation(fields: [familyUnitId], references: [id], onDelete: Restrict)
  userId       String
  user         User                @relation("AihFamilyUnitMember", fields: [userId], references: [id], onDelete: Restrict)
  role         AihFamilyMemberRole
  joinedAt     DateTime            @default(now())
  exitedAt     DateTime?

  @@unique([familyUnitId, userId])
  @@index([userId])
  @@index([familyUnitId])
  @@map("aih_family_unit_members")
}

/// Guardian ↔ Child relationship with permission level.
/// Drives all minor-governance escalation logic.
/// onDelete: Restrict — never cascade-delete; revoke via revokedAt instead.
model AihGuardianRelationship {
  id              String               @id @default(cuid())
  guardianUserId  String
  guardian        User                 @relation("AihGuardianOf", fields: [guardianUserId], references: [id], onDelete: Restrict)
  childUserId     String
  child           User                 @relation("AihChildOf", fields: [childUserId], references: [id], onDelete: Restrict)
  kind            AihGuardianKind
  permissionLevel AihGuardianPermLevel
  establishedAt   DateTime             @default(now())
  revokedAt       DateTime?

  @@unique([guardianUserId, childUserId])
  @@index([guardianUserId])
  @@index([childUserId])
  @@map("aih_guardian_relationships")
}

/// Persistent record of a governance escalation — a gated action awaiting guardian approval.
model AihApprovalRequest {
  id          String           @id @default(cuid())
  requestorId String
  requestor   User             @relation("AihApprovalRequestor", fields: [requestorId], references: [id], onDelete: Restrict)
  approverId  String
  approver    User             @relation("AihApprovalApprover", fields: [approverId], references: [id], onDelete: Restrict)
  actionKind  String
  state       AihApprovalState @default(pending)
  contextJson Json
  expiresAt   DateTime
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  aihMsgNotices AihMsgNotice[]

  @@index([approverId, state])
  @@index([requestorId])
  @@index([expiresAt])
  @@map("aih_approval_requests")
}

/// Durable audit log — governance decisions and significant actions.
/// actorId / targetId are plain strings (no FK) so events survive user deletion.
model AihAuditEvent {
  id        String   @id @default(cuid())
  kind      String
  actorId   String
  targetId  String?
  meta      Json
  createdAt DateTime @default(now())

  @@index([targetId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([kind])
  @@index([createdAt(sort: Desc)])
  @@map("aih_audit_events")
}

// ─── Activity layer (Agent 19) ────────────────────────────────────────────────
// Governed posts and comments scoped to trust units / family units.
// Every post carries visibilityScope and governanceState so the visibility
// service can answer "why can you see this?" at read time.

model AihActivityPost {
  id              String   @id @default(cuid())
  authorId        String
  trustUnitId     String?
  familyUnitId    String?
  visibilityScope String   @default("trust_unit")
  bodyText        String
  governanceState String   @default("allowed")
  escalationState String   @default("none")
  attachmentType  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author    User                 @relation("AihActivityPostAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  trustUnit TrustUnit?           @relation(fields: [trustUnitId], references: [id], onDelete: Restrict)
  comments  AihActivityComment[]

  @@index([trustUnitId, createdAt(sort: Desc)])
  @@index([familyUnitId, createdAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
  @@map("aih_activity_posts")
}

model AihActivityComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  post   AihActivityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User            @relation("AihActivityCommentAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  @@index([postId, createdAt(sort: Asc)])
  @@map("aih_activity_comments")
}

// ─── Policy Layer (Agent 37) ──────────────────────────────────────────────────
// Configurable governance policy layer. Sits above the deterministic governance
// kernel — adds founder-configurable overrides and per-user policy snapshots.
// All models are additive; no existing model is modified beyond the User back-relation.

/// Network-wide governance defaults set by the founder.
/// Application-level singleton: services use findFirst() / upsert.
/// founderUserId is a plain audit string — not a FK — so it survives role changes.
model AihFounderSettings {
  id                               String   @id @default(cuid())
  /// ID of the user who last saved these settings (audit only; no FK).
  founderUserId                    String?
  /// If true, any governed action by a minor routes to guardian approval.
  requireGuardianApprovalForMinors Boolean  @default(true)
  /// Whether minors may send invites (subject to guardian approval).
  allowMinorInvites                Boolean  @default(false)
  /// Whether minors may create posts.
  allowMinorPosting                Boolean  @default(true)
  /// Whether minors may include external links in posts.
  allowMinorExternalLinks          Boolean  @default(false)
  /// Default visibility scope applied to adult members. Must be a VisibilityScope value.
  defaultVisibilityScope           String   @default("family")
  /// Whether the trusted-adult guardian kind is enabled on this network.
  enableTrustedAdults              Boolean  @default(true)
  /// Whether private thread spaces (TRUST_UNIT scope) are enabled.
  enablePrivateThreads             Boolean  @default(true)
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt

  @@map("aih_founder_settings")
}

/// Per-user resolved policy snapshot.
/// Created at registration time by lib/aihsafe/policy/resolvePolicyProfile.ts.
/// JSON blobs store sub-policy overrides; null blobs use system+founder defaults.
/// ageTierSnapshot is refreshed whenever the user's age tier changes.
model AihPolicyProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// AgeTier value at last policy resolution. Refreshed on each re-resolution.
  ageTierSnapshot  String
  /// PolicySourceType value — provenance of this profile.
  sourceType       String   @default("system_default")
  /// PostingPolicy JSON — null = use system/founder defaults.
  postingPolicy    Json?
  /// InvitePolicy JSON — null = use system/founder defaults.
  invitePolicy     Json?
  /// VisibilityPolicy JSON — null = use system/founder defaults.
  visibilityPolicy Json?
  /// EscalationPolicy JSON — null = use system/founder defaults.
  escalationPolicy Json?
  /// InterestsPolicy JSON — null = use system/founder defaults. Populated by Agent 40.
  interestsPolicy  Json?
  /// LimitsPolicy JSON — null = use system/founder defaults. Populated by Agent 41.
  limitsPolicy     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("aih_policy_profiles")
}

// ─── Msg Vault — Governed Communication (Agent 49) ───────────────────────────
// Relationship-scoped conversations, messages, notices, and comm-layer audit detail.
// Does not replace AihAuditEvent. No open/stranger conversations — enforced in services.

enum AihMsgConversationKind {
  DIRECT
  THREAD
  NOTICE_THREAD
  SPACE_THREAD

  @@map("aih_msg_conversation_kind")
}

enum AihMsgConversationStatus {
  ACTIVE
  ARCHIVED
  LOCKED
  PENDING_APPROVAL

  @@map("aih_msg_conversation_status")
}

enum AihMsgParticipantRole {
  OWNER
  PARTICIPANT
  OBSERVER
  GUARDIAN
  MODERATOR

  @@map("aih_msg_participant_role")
}

enum AihMsgParticipantStatus {
  ACTIVE
  LEFT
  REMOVED
  PENDING

  @@map("aih_msg_participant_status")
}

enum AihMsgMessageStatus {
  SENT
  PENDING_APPROVAL
  REMOVED
  BLOCKED

  @@map("aih_msg_message_status")
}

enum AihMsgNoticeKind {
  APPROVAL_REQUIRED
  INVITE_ACCEPTED
  MEMBER_JOINED
  MEMBER_LEFT
  POLICY_CHANGED
  MESSAGE_BLOCKED
  POST_APPROVED
  POST_DENIED

  @@map("aih_msg_notice_kind")
}

enum AihMsgNoticeStatus {
  UNREAD
  READ
  ARCHIVED

  @@map("aih_msg_notice_status")
}

/// Governed direct chat or thread container. DIRECT rows use directKey for pair uniqueness.
model AihMsgConversation {
  id               String                   @id @default(cuid())
  kind             AihMsgConversationKind
  title            String?
  createdById      String
  createdBy        User                     @relation("AihMsgConversationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  trustUnitId      String?
  trustUnit        TrustUnit?               @relation(fields: [trustUnitId], references: [id], onDelete: Restrict)
  /// Sorted participant IDs for DIRECT kind — unique when set (A/B same as B/A).
  directKey        String?                  @unique
  /// Resolved policy + visibility rationale at creation time (explainability).
  policySnapshot   Json?
  /// VisibilityScope string — why participants may see this conversation.
  visibilityScope  String                   @default("trust_unit")
  status           AihMsgConversationStatus @default(ACTIVE)
  lastMessageAt    DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  participants     AihMsgParticipant[]
  messages         AihMsgMessage[]
  notices          AihMsgNotice[]
  governanceEvents AihMsgGovernanceEvent[]

  @@index([createdById])
  @@index([trustUnitId])
  @@index([status])
  @@index([lastMessageAt(sort: Desc)])
  @@index([kind, status])
  @@map("aih_msg_conversations")
}

/// Membership in a governed conversation — drives "who can participate".
model AihMsgParticipant {
  id             String                  @id @default(cuid())
  conversationId String
  conversation   AihMsgConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                    @relation(fields: [userId], references: [id], onDelete: Restrict)
  role           AihMsgParticipantRole   @default(PARTICIPANT)
  status         AihMsgParticipantStatus @default(ACTIVE)
  joinedAt       DateTime                @default(now())
  lastReadAt     DateTime?
  mutedAt        DateTime?

  @@unique([conversationId, userId])
  @@index([userId, status])
  @@index([conversationId, status])
  @@map("aih_msg_participants")
}

/// Individual governed message in a conversation.
model AihMsgMessage {
  id               String              @id @default(cuid())
  conversationId   String
  conversation     AihMsgConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorId         String
  author           User                @relation("AihMsgMessageAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  bodyText         String              @db.Text
  status           AihMsgMessageStatus @default(SENT)
  governanceState  String              @default("allowed")
  escalationState  String            @default("none")
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?

  governanceEvents AihMsgGovernanceEvent[]

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
  @@index([status])
  @@map("aih_msg_messages")
}

/// System/governance notice for Msg Vault (approvals, membership, policy).
model AihMsgNotice {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversationId    String?
  conversation      AihMsgConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  trustUnitId       String?
  approvalRequestId String?
  approvalRequest   AihApprovalRequest? @relation(fields: [approvalRequestId], references: [id], onDelete: SetNull)
  kind              AihMsgNoticeKind
  title             String
  body              String           @db.Text
  status            AihMsgNoticeStatus @default(UNREAD)
  createdAt         DateTime         @default(now())
  readAt            DateTime?

  @@index([userId, status, createdAt(sort: Desc)])
  @@index([conversationId])
  @@index([trustUnitId])
  @@index([approvalRequestId])
  @@map("aih_msg_notices")
}

/// Communication-layer governance detail (complements AihAuditEvent).
model AihMsgGovernanceEvent {
  id             String              @id @default(cuid())
  conversationId String?
  conversation   AihMsgConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  messageId      String?
  message        AihMsgMessage?      @relation(fields: [messageId], references: [id], onDelete: SetNull)
  actorUserId    String
  actor          User                @relation("AihMsgGovernanceEventActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  /// Plain string — no FK so events survive target user deletion.
  targetUserId   String?
  eventType      String
  contextJson    Json
  createdAt      DateTime            @default(now())

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([messageId])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([eventType])
  @@map("aih_msg_governance_events")
}

